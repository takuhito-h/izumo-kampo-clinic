    </div>\n    </footer>\n    <div id=\"sidr\" class=\"sidr right\">\n      <p class=\"close\">\n        <a href=\"javascript:void(0)\" class=\"mobile_menu\">Close</a>\n      </p>\n      <p class=\"backhome\"><a href=\"top-redesign.preview.html\">HOME</a></p>\n      <div class=\"banner smart_phonetop\">\n        <ul>\n          <li>\n            <a href=\"https://lin.ee/J5alWzJ\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_line.png\" alt=\"LINE公式アカウント問い合わせ\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"reserve-redesign.preview.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_reserve.png\" alt=\"診療予約について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"q_and_a-redesign.preview.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/10/4d767dee6af9188b3d6c0424c1a66b01.png\"\n                alt=\"よくある質問\" data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"partnership-shinkyu.preview.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/05/Twitter.png\" alt=\"提携鍼灸院について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"blog-redesign.preview.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/03/53dca034c608bbba0219914e69b10442-1.png\"\n                alt=\"院長ブログ\" data-eio=\"j\" />\n            </a>\n          </li>\n        </ul>\n      </div>\n      <ul id=\"menu-main_menu\" class=\"menu\">\n        <li\n          class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-home menu-item-125\">\n          <a href=\"top-redesign.preview.html\">ホーム</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-2204\">\n          <a href=\"clinic-redesign.preview.html\">クリニックのご案内</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-30\">\n          <a href=\"doctor-redesign.preview.html\">医師のご紹介</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1432\">\n          <a href=\"kampo-redesign.preview.html\">漢方治療について</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1746\">\n          <a href=\"online-redesign.preview.html\">オンライン診療について</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-28\">\n          <a href=\"time-redesign.preview.html\">診療時間・アクセス</a>\n        </li>\n      </ul>\n      <div class=\"banner smart_phonebottom\">\n        <ul>\n          <li>\n            <p>\n              <strong>公式SNS</strong>\n            </p>\n          </li>\n          <li>\n            <a href=\"https://izumo-kampo.clinic/izumo_kampo_youtube/\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/02/Twitter-2.png\" alt=\"Youtube\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"https://twitter.com/wjHhI0T0zPl0TnO\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/09/Twitter.png\" alt=\"院長Twitter\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"https://www.instagram.com/izumoanz/\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2026/03/Twitter.png\" alt=\"あんず鍼灸院Instagram\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <!-- wp_footer contents -->\n\n  <!-- Invalid GA4 Measurement ID -->\n  <!-- Custom Feeds for Instagram JS -->\n\n  <inp