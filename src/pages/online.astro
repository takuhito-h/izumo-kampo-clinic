---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "出雲漢方クリニック｜オンライン診療 デザインリニューアル案（共通CSS使用）";
const content = "<input type=\"hidden\" id=\"telnum\" value=\"\" />\n\n  <!-- Google Tag Manager (noscript) -->\n\n  <!-- End Google Tag Manager (noscript) -->\n  <div id=\"wrapper\" class=\"page_weverysub parent1691 my1691 cat pcat\">\n    <div id=\"mobile\">\n      <a href=\"javascript:void(0)\" class=\"mobile_menu\"><img\n          src=\"https://izumo-kampo.clinic/wp-content/themes/theme/img/menu_bt.png\" alt=\"メニュー\" class=\"top_menu\"\n          width=\"100%\" height=\"auto\" /></a>\n    </div>\n\n    <header id=\"header\">\n      <h1>\n        <a href=\"/top.html\"><span class=\"cliniclogo\"><img\n              src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/04/S__63782986.png\" alt=\"出雲漢方クリニック\"\n              class=\"cliniclogo_img\" data-eio=\"j\" /></span><span class=\"h1_text\">出雲漢方クリニック</span></a>\n      </h1>\n\n      <div class=\"header_text\">\n        <p>【保険診療】 漢方内科 呼吸器内科・外科 アレルギー科</p>\n      </div>\n\n      <div class=\"header_address\">\n        <p>\n          島根県出雲市今市町736-11\n          出雲市駅から徒歩5分、全国オンライン診療受付中&nbsp;[<a href=\"https://izumo-kampo.clinic?p=23\">地図へ</a>]\n        </p>\n      </div>\n\n      <div class=\"header_tel\">\n        <p class=\"tel\"><i class=\"material-icons\">local_phone</i></p>\n      </div>\n\n      <div class=\"header_week\">\n        <!-- <p>休診日　<br /><a href=\"?p=22\">診療時間はこちら</a></p> -->\n        <p>\n          休診日：　土・日<br /><a href=\"https://izumo-kampo.clinic?p=22\">診療時間はこちら</a>\n        </p>\n      </div>\n      <div style=\"clear: both\"></div>\n      <form role=\"search\" method=\"get\" id=\"searchform\" action=\"/top.html\">\n        <div id=\"page_search\">\n          <label class=\"screen-reader-text\" for=\"s\"></label>\n\n          <input type=\"text\" value=\"\" name=\"s\" id=\"s\" placeholder=\"サイト内検索\" />\n\n          <input type=\"image\" src=\"https://izumo-kampo.clinic/wp-content/themes/theme/img/toolbar_find.png\"\n            id=\"searchsubmit\" value=\"検索\" />\n        </div>\n      </form>\n\n      <div id=\"header_add\">\n        <!-- ヘッダーに記載する内容（#header_add） -->\n      </div>\n\n      <!-- / #header -->\n    </header>\n\n    <div id=\"gNav\" class=\"\">\n      <ul id=\"nav\" class=\"menu\">\n        <li id=\"menu-item-125\"\n          class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-home menu-item-125\">\n          <a href=\"/top.html\">ホーム</a>\n        </li>\n        <li id=\"menu-item-2204\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-2204\">\n          <a href=\"/clinic.html\">クリニックのご案内</a>\n        </li>\n        <li id=\"menu-item-30\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-30\">\n          <a href=\"/doctor.html\">医師のご紹介</a>\n        </li>\n        <li id=\"menu-item-1432\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1432\">\n          <a href=\"/kampo.html\">漢方治療について</a>\n        </li>\n        <li id=\"menu-item-1746\"\n          class=\"menu-item menu-item-type-post_type menu-item-object-page current-menu-item page_item page-item-1691 current_page_item menu-item-1746\">\n          <a href=\"/online.html\" aria-current=\"page\">オンライン診療について</a>\n        </li>\n        <li id=\"menu-item-28\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-28\">\n          <a href=\"/time.html\">診療時間・アクセス</a>\n        </li>\n      </ul>\n      <!-- / #gNav -->\n    </div>\n    <section id=\"wv_headbtn\">\n      <ul class=\"wv_headbtn_1\">\n        <li>\n          <a href=\"https://clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online\"\n            target=\"_blank\" rel=\"nofollow\"><span class=\"spf_word\">診療を予約する</span></a>\n        </li>\n      </ul>\n    </section>\n    <div id=\"contents\">\n      <div id=\"top_contents\">\n        <!-- コンテンツの上部に記載する内容（#top_contents） -->\n      </div>\n      <div id=\"main\">\n        <div id=\"breadcrumbs\">\n          <a href=\"/top.html\">ホーム</a> &gt;\n          オンライン診療について\n        </div>\n\n        <article>\n          <section class=\"pageSec\">\n            <h2 class=\"h2_1691\">オンライン診療について</h2>\n            <div class=\"mb-3\">\n              <img class=\"article-thumbnail\"\n                src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/06/3ffbb34faf3d37f3574b3fd8ae5f2499-e1659787053758.jpg\"\n                alt=\"\" data-eio=\"j\" />\n            </div>\n            <div class=\"subpagecontents\">\n              <p>\n                出雲漢方クリニックは、<strong>初診から再診までオンライン診療対応（保険診療）のクリニック</strong>です。<strong>患者さんの７割がオンラインで受診</strong>されています。 \n              </p>\n              <p>\n                北は北海道から、南は沖縄まで。全国の患者さんにご利用いただいております。\n              </p>\n              <div class=\"block_index\">\n                <strong>目次</strong>\n                <ul>\n                  <li><a href=\"#anchor-feature\">オンライン診療の特徴</a></li>\n                  <li><a href=\"#anchor-flow\">オンライン診療の流れ</a></li>\n                  <li><a href=\"#anchor-worries\">こんなお悩みにどうぞ</a></li>\n                  <li><a href=\"#anchor-doctor\">診察する医師のご紹介</a></li>\n                  <li>\n                    <a href=\"#anchor-youtube\">オンライン診療の動画解説（Youtube）</a>\n                  </li>\n                  <li>\n                    <a href=\"#anchor-coverage\">当院の診療が取材されました</a>\n                  </li>\n                  <li><a href=\"#anchor-menu\">診療メニューのご紹介</a></li>\n                </ul>\n              </div>\n              <h3 id=\"anchor-feature\">オンライン診療の特徴</h3>\n              <h4>あなたの症状や悩み事を、医師が漢方でサポートいたします</h4>\n              <p>\n                ビデオ通話で問診をおこない、舌の状態から内臓の状態を確かめ、処方する漢方薬を決定いたします。\n              </p>\n              <p>\n                治療は基本的に漢方薬で行いますが、西洋薬の方がいいと判断した場合や、患者さまのご希望がありましたら西洋薬も処方いたします。ご相談ください。\n              </p>\n              <h4>気軽に自宅で診療</h4>\n              <p>\n                <img decoding=\"async\"\n                  src=\"https://ferret-one.akamaized.net/images/6901ea6358d08505a78ce228/original.png?utime=1761733219\"\n                  alt=\"オンライン診療「クリニクス」スマホで受診できる\" width=\"150\" />\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/clinics-merit03.png\"\n                  alt=\"オンライン診療「クリニクス」薬・処方箋が届く\" width=\"150\" />\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/clinics-merit04.png\"\n                  alt=\"オンライン診療「クリニクス」24時間予約が可能\" width=\"150\" />\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/clinics-merit05.png\"\n                  alt=\"オンライン診療「クリニクス」往復交通費ゼロ\" width=\"150\" />\n              </p>\n              <p>\n                オンライン診療なので、<strong>移動せず自宅でゆっくりとスマホのビデオ通話で診療</strong>いただけます。\n              </p>\n              <p>\n                待ち時間も最長で予約時間から20分ほど。待ち時間の間もご自宅で仕事や家事が可能です。\n              </p>\n              <p>移動時間不要で、また土日の診療にも対応しています。</p>\n              <ul>\n                <li>時間がなくて病院に行けない</li>\n                <li>漢方薬を試してみたいけど、近くに漢方クリニックがない</li>\n              </ul>\n              <p>そんなお悩みがある方は、オンライン診療をご利用ください。</p>\n              <h4>薬のお受け取りもご自宅で完結</h4>\n              <p>\n                <strong>院内処方（郵送）</strong>をお選びいただければ、<strong>調剤薬局まで漢方薬を受け取りに行く必要がありません</strong>。\n              </p>\n              <p>\n                地域によって多少の差がありますが、診療いただいた日から1〜2日ほどでお薬を受け取りいただけます。\n              </p>\n              <h3 id=\"anchor-flow\">オンライン診療の流れ</h3>\n              <h4>1.診療予約</h4>\n              <div class=\"block-emphasis\">\n                <p>\n                  ※現在、初診、再診ともに混み合っておりまして、直近での予約が取りづらい状況になっております。\n                </p>\n                <p>\n                  診療の前日、当日にキャンセルが出ることが多くなっています。診療の前日、当日にキャンセルが出ることが多くなってます。キャンセル待ちをされたい方がいましたら、<a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/izumo-kampo.clinic/reserve#anchor-waiting-list',\n                        );\n                      \"\n                    href=\"https://izumo-kampo.clinic/reserve#anchor-waiting-list\">キャンセル待ちについて</a>に記載してある手順でお申し込みください。\n                </p>\n              </div>\n              <p>\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/img-guide-reservation.png\"\n                  alt=\"オンライン診療「クリニクス」 オンライン診療の予約\" width=\"220\" />\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online',\n                      );\n                    \"\n                  href=\"https://clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online\"\n                  target=\"_blank\"\n                  rel=\"noopener noreferrer\">melmoの予約ページ</a>から診療メニューを選択（分からない場合はオンライン漢方外来を選択）し、空いてる予約枠の中から<strong>予約日時を選択</strong>します。\n              </p>\n              <p>\n                次にアカウント登録画面になるので名前や住所などの情報、クレジットカード情報、保険証情報を入力し、アカウントを登録します（登録無料）。\n              </p>\n              <div class=\"block-emphasis\">\n                <p>\n                  ※お子さんが受診される場合は、親御さんのアカウントに家族アカウントとしてお子さんを追加する必要があります。詳しくは<a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/izumo-kampo.clinic/for_children',\n                        );\n                      \" href=\"https://izumo-kampo.clinic/for_children\" target=\"_blank\"\n                    rel=\"noopener noreferrer\">こちらのページ</a>をご覧ください。\n                </p>\n              </div>\n              <div class=\"block-emphasis\">\n                <p>\n                  ※ご都合の良い時間帯の予約が取れない場合は、「予約時間の相談をしたい」と<a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/lin.ee/SGqyO4q',\n                        );\n                      \" href=\"https://lin.ee/SGqyO4q\" target=\"_blank\"\n                    rel=\"noopener noreferrer\">LINE公式アカウント</a>でお伝えください。時間を調整させていただきます。\n                </p>\n              </div>\n              <h4>2.melmoアプリのインストール</h4>\n              <p>\n                予約が終わったらmelmo<strong>（オンライン診療アプリ：ダウンロード、利用ともに無料）</strong>をスマホにダウンロードし、予約したアカウントでログインします。\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/apps.apple.com/us/app/clinics-%E3%82%AF%E3%83%AA%E3%83%8B%E3%82%AF%E3%82%B9-%E3%82%AA%E3%83%B3%E3%83%A9%E3%82%A4%E3%83%B3%E8%A8%BA%E7%99%82-%E6%9C%8D%E8%96%AC%E6%8C%87%E5%B0%8E%E3%82%A2%E3%83%97%E3%83%AA/id1106261604?itsct=apps_box_badge&amp;itscg=30200',\n                      );\n                    \" style=\"\n                      display: inline-block;\n                      overflow: hidden;\n                      border-radius: 13px;\n                      width: 125px;\n                      height: 50px;\n                      vertical-align: top;\n                    \"\n                  href=\"https://apps.apple.com/us/app/clinics-%E3%82%AF%E3%83%AA%E3%83%8B%E3%82%AF%E3%82%B9-%E3%82%AA%E3%83%B3%E3%83%A9%E3%82%A4%E3%83%B3%E8%A8%BA%E7%99%82-%E6%9C%8D%E8%96%AC%E6%8C%87%E5%B0%8E%E3%82%A2%E3%83%97%E3%83%AA/id1106261604?itsct=apps_box_badge&amp;itscg=30200\"\n                  target=\"_blank\" rel=\"noopener noreferrer\"><img decoding=\"async\" class=\"alignnone\"\n                    style=\"border-radius: 13px; width: 125px; height: 50px\"\n                    src=\"https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/ja-jp?size=250x83&amp;releaseDate=1464220800?h=cfbd1c54bf48f417a4aad808c338ffe6\"\n                    alt=\"Download on the App Store\" width=\"109\" height=\"40\" /></a>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/play.google.com/store/apps/details?id=life.medley.clinics&amp;pcampaignid=pcampaignidMKT-Other-global-all-co-prtnr-py-PartBadge-Mar2515-1',\n                      );\n                    \" style=\"vertical-align: top\"\n                  href=\"https://play.google.com/store/apps/details?id=life.medley.clinics&amp;pcampaignid=pcampaignidMKT-Other-global-all-co-prtnr-py-PartBadge-Mar2515-1\"\n                  target=\"_blank\" rel=\"noopener noreferrer\"><img decoding=\"async\" class=\"alignnone\"\n                    style=\"margin-top: -3px\"\n                    src=\"https://play.google.com/intl/ja/badges/static/images/badges/ja_badge_web_generic.png\"\n                    alt=\"Google Play で手に入れよう\" width=\"150\" height=\"250\" /></a>\n              </p>\n              <h4>3.LINE公式アカウントを追加する</h4>\n              <p>\n                オンライン診療が繋がらない場合にLINE公式アカウントを通じて連絡いたしますので、受診前に以下のボタンからLINE公式アカウントを追加ください。\n              </p>\n              <p>\n                追加しましたら、カルテと照合するためにお名前が必要になりますので、LINE公式アカウントのチャットで「お名前」をフルネームでお送りください。\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/lin.ee/SGqyO4q',\n                      );\n                    \" class=\"big-button\" href=\"https://lin.ee/SGqyO4q\" target=\"_blank\"\n                  rel=\"noopener noreferrer\">LINE公式アカウントを友達追加する</a>\n              </p>\n              <h4>4.オンライン診療</h4>\n              <p>\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/img-guide-telemedicine.png\"\n                  alt=\"オンライン診療「クリニクス」 オンライン診療\" width=\"220\" />\n              </p>\n              <p>\n                予約した時間以降（待ち時間が最大20分ほど発生します）にお呼び出しをいたしますので、スマホをお近くに置いて呼び出しをお待ちください。\n              </p>\n              <p>\n                あなたがお困りの病気や症状について、<strong>melmoのアプリを通じて医師が診療</strong>します。診療時間の目安は初診で20分程度、再診で7分程度とお考えください。\n              </p>\n              <div class=\"block-emphasis\">\n                <p>\n                  ※ご予約された時間には複数の患者さんの予約が入っていますので、待ち時間が最大で20分ほど発生します。時間になって呼び出しがなくても、あせらず呼び出しがあるまでお待ちください。<br />\n                  <br />\n                  20分以上待機して呼び出しされない場合は、お手数ですが<a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/lin.ee/SGqyO4q',\n                        );\n                      \" href=\"https://lin.ee/SGqyO4q\" target=\"_blank\"\n                    rel=\"noopener noreferrer\">LINE公式アカウント</a>へメッセージをお送りください。\n                </p>\n              </div>\n              <h4>5.お会計</h4>\n              <p>\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/img-guide-accounting.png\"\n                  alt=\"オンライン診療「クリニクス」 アプリでお会計\" width=\"220\" />\n              </p>\n              <p>\n                診察の結果、確定した金額でクレジットカードにご請求させていただきます。\n                保険適用時の自己負担費用としましては、<strong>2,000〜5,000円ほど（</strong>受診料[初診料、再診料ほか]、薬剤費、通信料を含めて<strong>）</strong>となっております。\n              </p>\n              <p>\n                ※\n                オンライン診療は<strong>クレジットカード払いのみ対応</strong>となっていますので、ご注意ください。対面診療では現金でのお支払いを承っております。\n              </p>\n              <h4>6.漢方薬の処方</h4>\n              <p>\n                <img decoding=\"async\" src=\"https://clinics-cloud.com/img/media-kit/img-guide-delivery.png\"\n                  alt=\"オンライン診療「クリニクス」 お薬・処方箋の受け取り\" width=\"220\" />\n              </p>\n              <p>\n                診断に基づいた漢方薬をお受け取りいただきます。<strong>お近くの調剤薬局でお受け取りいただくか（院外処方）</strong>、<strong>出雲漢方クリニックから郵送で漢方薬をお受け取りいただくか（院内処方）</strong>、どちらかをお選びください。\n              </p>\n              <p>\n                なお、薬の処方量はオンライン診療時には<strong>初診で最大7日分</strong>、<strong>再診で最大30日分</strong>と決められております。ご了承ください。\n              </p>\n              <p>\n                ※\n                漢方薬は通常の調剤薬局には在庫がないことが多いため、院内処方をオススメしております。院内処方の場合、送料を<strong>別途650〜800円（税込）</strong>いただいております。\n              </p>\n              <h3 id=\"anchor-worries\">こんなお悩みにどうぞ</h3>\n              <ul>\n                <li>自分の症状や体質に合った漢方薬が欲しい</li>\n                <li>\n                  近くに漢方クリニックがないので、漢方薬を処方して欲しい\n                </li>\n                <li>\n                  今漢方を飲んでいるが、この漢方でいいのか気になっている\n                </li>\n                <li>漢方を使った肥満対策、高血圧対策をしたい</li>\n              </ul>\n              <h3 id=\"anchor-doctor\">診察する医師のご紹介</h3>\n              <p>\n                <img decoding=\"async\" class=\"wp-image-1307 alignnone\"\n                  src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/06/fffb166affaac3a2ac359a84542b712a.jpg\"\n                  alt=\"\" width=\"200\" height=\"217\" srcset=\"\n                      https://izumo-kampo.clinic/wp-content/uploads/2022/06/fffb166affaac3a2ac359a84542b712a.jpg         854w,\n                      https://izumo-kampo.clinic/wp-content/uploads/2022/06/fffb166affaac3a2ac359a84542b712a-277x300.jpg 277w,\n                      https://izumo-kampo.clinic/wp-content/uploads/2022/06/fffb166affaac3a2ac359a84542b712a-221x240.jpg 221w,\n                      https://izumo-kampo.clinic/wp-content/uploads/2022/06/fffb166affaac3a2ac359a84542b712a-768x833.jpg 768w\n                    \" sizes=\"(max-width: 200px) 100vw, 200px\" data-eio=\"j\" />\n              </p>\n              <p>\n                出雲漢方クリニック院長 / 島根大学医学部 漢方医学 臨床教授<br />\n                <strong>宮本　信宏</strong>\n              </p>\n              <p>\n                外科医を20年以上経験し、西洋医学には苦手分野があることに気づき、漢方薬の大きな可能性に気づきました。西洋医学で及ばないところを東洋医学でカバーしていくという考え方のもと、漢方診察をおこなっております。\n              </p>\n              <p>\n                小児から高齢者まで、年齢性別を問わず、西洋医学でうまくいかない患者さんを診察しています。\n              </p>\n              <p>\n                病院に行っても良くならない体の悩みは、漢方で楽になるかもしれません。お気軽にご相談ください。\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/izumo-kampo.clinic/doctor',\n                      );\n                    \" class=\"big-button css_btn_class\" href=\"/doctor.html\"\n                  rel=\"noopener noreferrer\">医師について詳しく知る</a>\n              </p>\n              <h3 id=\"anchor-youtube\">オンライン診療の動画解説（Youtube）</h3>\n              <p>\n                動画でもオンライン診療について解説しています。医師の雰囲気が知りたい方、オンライン診療について詳しく知りたい方はぜひご覧ください。\n              </p>\n              <h4>宮本が漢方医になった理由、オンライン診療の流れ</h4>\n              <p>\n                <iframe loading=\"lazy\" class=\"iframe-youtube\" title=\"【誰でも簡単】オンライン診療のやり方\"\n                  src=\"https://www.youtube.com/embed/BW-FImD2kz8?feature=oembed\" width=\"100%\" height=\"400\"\n                  frameborder=\"0\" allowfullscreen=\"allowfullscreen\" data-mce-fragment=\"1\"></iframe>\n              </p>\n              <h4>初診での費用（診察代、薬代）はどれくらい？</h4>\n              <p>\n                <iframe loading=\"lazy\" class=\"iframe-youtube\" title=\"YouTube video player\"\n                  src=\"https://www.youtube.com/embed/ZmCxMaNvjhs?si=bx_vNERIy7y8cDen\" width=\"100%\" height=\"400\"\n                  frameborder=\"0\" allowfullscreen=\"allowfullscreen\"><span data-mce-type=\"bookmark\" style=\"\n                        display: inline-block;\n                        width: 0px;\n                        overflow: hidden;\n                        line-height: 0;\n                      \" class=\"mce_SELRES_start\">﻿</span><span data-mce-type=\"bookmark\" style=\"\n                        display: inline-block;\n                        width: 0px;\n                        overflow: hidden;\n                        line-height: 0;\n                      \" class=\"mce_SELRES_start\">﻿</span></iframe>\n              </p>\n              <h3 id=\"anchor-coverage\">メディア掲載</h3>\n              <ul>\n                <li>\n                  <a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/doctorsfile.jp/h/202912/df/1/',\n                        );\n                      \" href=\"https://doctorsfile.jp/h/202912/df/1/\" target=\"_blank\"\n                    rel=\"noopener noreferrer\">漢方は先端医療の弱点を補う頼もしい存在（Doctors File）</a>\n                </li>\n                <li>\n                  <a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/clinics-cloud.com/online/case/35',\n                        );\n                      \" href=\"https://clinics-cloud.com/online/case/35\" target=\"_blank\" rel=\"noopener noreferrer\"><span\n                      class=\"font-size-36px\">7割の診察はオンライン！受診しやすい環境でもっと気軽に漢方を（CLINICS）</span></a>\n                </li>\n                <li>\n                  <a onclick=\"\n                        javascript: pageTracker._trackPageview(\n                          '/outgoing/www.qlife-kampo.jp/disease-kampo/story12724.html',\n                        );\n                      \" href=\"https://www.qlife-kampo.jp/disease-kampo/story12724.html\" target=\"_blank\"\n                    rel=\"noopener noreferrer\">漢方薬はダイエットや肥満解消に役立つ？　肥満・高血圧外来の医師が解説（QLife漢方）</a>\n                </li>\n              </ul>\n              <h3 id=\"anchor-menu\">診療メニューのご紹介</h3>\n              <h4>オンライン漢方外来</h4>\n              <p>\n                風邪やコロナ感染症後の倦怠感や咳、雨の日の頭痛、生理の時の腹痛やニキビ、更年期のイライラ、慢性の下痢や便秘など、お気軽にご相談ください。\n              </p>\n              <p>\n                保険診療内で漢方医学的診断を行い、漢方薬を処方いたします。\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/izumo-kampo.clinic/kampo',\n                      );\n                    \" class=\"big-button css_btn_class\" href=\"/kampo.html\"\n                  rel=\"noopener noreferrer\">漢方治療について詳しく知る</a>\n              </p>\n              <h4> オンライン肥満・高血圧外来</h4>\n              <p>\n                肥満と高血圧で悩んでいませんか？\n                食事療法と漢方薬を併用することで、生活習慣の改善から体重減少と適正な血圧のコントロールを指導します。\n              </p>\n              <p>\n                現在の血圧のお薬と併用も可能ですので、お気軽にご相談ください。\n              </p>\n              <p>\n                <a onclick=\"\n                      javascript: pageTracker._trackPageview(\n                        '/outgoing/izumo-kampo.clinic/kampo_diet',\n                      );\n                    \" class=\"big-button css_btn_class\" href=\"https://izumo-kampo.clinic/kampo_diet\"\n                  rel=\"noopener noreferrer\">肥満外来について詳しく知る</a>\n              </p>\n              <h4>オンライン発熱外来</h4>\n              <p>\n                風邪、インフルエンザ、コロナウイルス感染症をご相談いただけます。院長は呼吸器が専門で、発熱外来で新型コロナウイルス検査1000件とワクチン接種１万件の経験があります。\n              </p>\n              <p>\n                病院受診の必要性を検討し、現在の症状からおすすめの漢方薬と解熱剤を提案します。\n              </p>\n              <h4 class=\"sc-1bc1cec3-0 hbqAbX\">迅速漢方外来</h4>\n              <p>\n                短い時間での漢方薬の処方を希望される、忙しい患者さま向けの漢方外来です。<br />\n                通常の漢方外来の初診では20分、再診では6分ほどの診療時間をいただいているところ、初診10分前後、再診3分ほどで診療いたします。\n              </p>\n              <p>\n                時間が短いため、他の外来の予約枠が空いていない時でも予約を取れる場合がございます。一度ご確認ください。\n              </p>\n            </div>\n          </section>\n        </article>\n        <!-- / #main -->\n      </div>\n\n      <div id=\"sideMenu\">\n        <p class=\"backhome\"><a href=\"/top.html\">HOME</a></p>\n\n        <div class=\"banner bn_top spnone\">\n          <!-- 2011.11.13変更 -->\n          <ul>\n            <li>\n              <a href=\"https://lin.ee/J5alWzJ\" target=\"_blank\" rel=\"nofollow\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_line.png\" alt=\"LINE公式アカウント問い合わせ\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"/reserve.html\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_reserve.png\" alt=\"診療予約について\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"/q_and_a.html\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/10/4d767dee6af9188b3d6c0424c1a66b01.png\"\n                  alt=\"よくある質問\" data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"/partnership-shinkyu.html\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/05/Twitter.png\" alt=\"提携鍼灸院について\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"/blog.html\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/03/53dca034c608bbba0219914e69b10442-1.png\"\n                  alt=\"院長ブログ\" data-eio=\"j\" />\n              </a>\n            </li>\n          </ul>\n        </div>\n\n        <div class=\"banner bn_top spnone sidemenu_bottom\">\n          <!-- 2011.11.13変更 -->\n          <ul>\n            <li>\n              <p><strong>公式SNS</strong></p>\n            </li>\n\n            <li>\n              <a href=\"https://izumo-kampo.clinic/izumo_kampo_youtube/\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/02/Twitter-2.png\" alt=\"Youtube\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"https://twitter.com/wjHhI0T0zPl0TnO\" target=\"_blank\" rel=\"nofollow\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/09/Twitter.png\" alt=\"院長Twitter\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n\n            <li>\n              <a href=\"https://www.instagram.com/izumoanz/\" target=\"_blank\" rel=\"nofollow\">\n                <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2026/03/Twitter.png\" alt=\"あんず鍼灸院Instagram\"\n                  data-eio=\"j\" />\n              </a>\n            </li>\n          </ul>\n        </div>\n\n        <!--<div class=\"qr\">\n\n<img src=\"https://chart.googleapis.com/chart?chs=100x100&cht=qr&chl=https://izumo-kampo.clinic\" />\n<p>スマートフォンに対応しています。</p>\n</div>-->\n\n        <div id=\"side_add\">\n          <!-- サイドメニュー下部に記載する内容（#side_add） -->\n        </div>\n\n        <!-- / #sideMenu -->\n      </div>\n\n      <div id=\"bottom_contents\">\n        <!-- コンテンツの上部に記載する内容（#bottom_contents） -->\n      </div>\n      <div class=\"banner smart_phone\">\n        <ul></ul>\n      </div>\n    </div>\n    <div class=\"pagetop\"><a href=\"#header\">▲ ページのトップに戻る</a></div>\n    <footer id=\"footer\">\n      <div id=\"footer_area\">\n        <h2 class=\"footer_sitename\">\n          <a href=\"/top.html\">出雲漢方クリニック</a>\n        </h2>\n        <p class=\"footer_youso\">\n          <span class=\"footer_clinickamoku\">\n            【保険診療】 漢方内科 呼吸器内科・外科 アレルギー科 <br /></span>\n          <span class=\"footer_clinicaddress\">島根県出雲市今市町736-11</span><span class=\"footer_clinicbuilding\"></span><span\n            class=\"footer_clinictraffic\">　出雲市駅から徒歩5分、全国オンライン診療受付中　[<a\n              href=\"https://izumo-kampo.clinic?p=23\">地図へ</a>]<br /></span>\n          <span class=\"footer_clinicholiday\">休診日：　土・日</span>\n        </p>\n        <div id=\"footer_add\">\n          <!-- フッターに記載する内容（#bottom_contents） -->\n        </div>\n        <div id=\"add_footer_data\"></div>\n        <address class=\"address\">\n          Copyright &copy; 出雲漢方クリニック All Rights Reserved.\n        </address>\n      </div>\n    </footer>\n    <div id=\"sidr\" class=\"sidr right\">\n      <p class=\"close\">\n        <a href=\"javascript:void(0)\" class=\"mobile_menu\">Close</a>\n      </p>\n      <p class=\"backhome\"><a href=\"/top.html\">HOME</a></p>\n      <div class=\"banner smart_phonetop\">\n        <ul>\n          <li>\n            <a href=\"https://lin.ee/J5alWzJ\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_line.png\" alt=\"LINE公式アカウント問い合わせ\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/reserve.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_reserve.png\" alt=\"診療予約について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/q_and_a.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/10/4d767dee6af9188b3d6c0424c1a66b01.png\"\n                alt=\"よくある質問\" data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/partnership-shinkyu.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/05/Twitter.png\" alt=\"提携鍼灸院について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/blog.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/03/53dca034c608bbba0219914e69b10442-1.png\"\n                alt=\"院長ブログ\" data-eio=\"j\" />\n            </a>\n          </li>\n        </ul>\n      </div>\n      <ul id=\"menu-main_menu\" class=\"menu\">\n        <li\n          class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-home menu-item-125\">\n          <a href=\"/top.html\">ホーム</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-2204\">\n          <a href=\"/clinic.html\">クリニックのご案内</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-30\">\n          <a href=\"/doctor.html\">医師のご紹介</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1432\">\n          <a href=\"/kampo.html\">漢方治療について</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1746\">\n          <a href=\"/online.html\">オンライン診療について</a>\n        </li>\n        <li class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-28\">\n          <a href=\"/time.html\">診療時間・アクセス</a>\n        </li>\n      </ul>\n      <div class=\"banner smart_phonebottom\">\n        <ul>\n          <li>\n            <p>\n              <strong>公式SNS</strong>\n            </p>\n          </li>\n          <li>\n            <a href=\"https://izumo-kampo.clinic/izumo_kampo_youtube/\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/02/Twitter-2.png\" alt=\"Youtube\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"https://twitter.com/wjHhI0T0zPl0TnO\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/09/Twitter.png\" alt=\"院長Twitter\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"https://www.instagram.com/izumoanz/\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2026/03/Twitter.png\" alt=\"あんず鍼灸院Instagram\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n\n  <!-- wp_footer contents -->\n\n  <!-- Invalid GA4 Measurement ID -->\n  <!-- Custom Feeds for Instagram JS -->\n\n  <input name=\"assist\" type=\"hidden\" value=\"\" /><input name=\"movie_play\" type=\"hidden\" value=\"1\" />\n\n  <!-- wp_footer contents end -->\n\n  <section id=\"sp_footer\">\n    <ul>\n      <li>\n        <a href=\"https://lin.ee/aYfwiH0\" target=\"_blank\" rel=\"nofollow\"><i\n            class=\"material-icons\">contact_support</i><span class=\"spf_word\">問い合わせ（LINE）</span></a>\n      </li>\n      <li>\n        <a href=\"https://clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online\"\n          target=\"_blank\" rel=\"nofollow\"><i class=\"material-icons\">contact_page</i><span\n            class=\"spf_word\">診療予約</span></a>\n      </li>\n    </ul>\n  </section>";
