>\n        </div>\n      </form>\n\n      <div id=\"header_add\">\n        <!-- ヘッダーに記載する内容（#header_add） -->\n      </div>\n\n      <!-- / #header -->\n    </header>\n\n    <div id=\"gNav\" class=\"\">\n      <ul id=\"nav\" class=\"menu\">\n        <li id=\"menu-item-125\"\n          class=\"menu-item menu-item-type-custom menu-item-object-custom menu-item-home menu-item-125\">\n          <a href=\"top-redesign.preview.html\">ホーム</a>\n        </li>\n        <li id=\"menu-item-2204\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-2204\">\n          <a href=\"clinic-redesign.preview.html\">クリニックのご案内</a>\n        </li>\n        <li id=\"menu-item-30\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-30\">\n          <a href=\"doctor-redesign.preview.html\">医師のご紹介</a>\n        </li>\n        <li id=\"menu-item-1432\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1432\">\n          <a href=\"kampo-redesign.preview.html\">漢方治療について</a>\n        </li>\n        <li id=\"menu-item-1746\"\n          class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-1746\">\n          <a href=\"online-redesign.preview.html\">オンライン診療について</a>\n        </li>\n        <li id=\"menu-item-28\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-28 current-menu-item current_page_item\">\n          <a href=\"time-redesign.preview.html\">診療時間・アクセス</a>\n        </li>\n      </ul>\n      <!-- / #gNav -->\n    </div>\n    <section id=\"wv_headbtn\">\n      <ul class=\"wv_headbtn_1\">\n        <li>\n          <a href=\"https://clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online\"\n            target=\"_blank\" rel=\"nofollow\"><span class=\"spf_word\">診療を予約する</span></a>\n        </li>\n      </ul>\n    </section>\n    <div id=\"contents\">\n      <div id=\"top_contents\">\n        <!-- コンテンツの上部に記載する内容（#top_contents） -->\n      </div>\n      <div id=\"main\">\n        <div id=\"breadcrumbs\">\n          <a href=\"top-redesign.preview.html\">ホーム</a> &gt;\n          診療時間・アクセス\n        </div>\n\n        <article>\n          <section class=\"pageSec\">\n\n\n<h2 class=\"h2_22\">診療時間・アクセス</h2>\n<div class=\"subpagecontents\">\n<p>当院は予約制となっています。当日予約も受け付けていますので、お気軽にご予約ください。</p>\n\n<table id=\"tablepress-1-no-2\" class=\"tablepress tablepress-id-1 time_table\">\n<thead>\n<tr class=\"row-1 odd\">\n\t<th class=\"column-1\">診療時間</th><th class=\"column-2\">月</th><th class=\"column-3\">火</th><th class=\"column-4\">水</th><th class=\"column-5\">木</th><th class=\"column-6\">金</th><th class=\"column-7\">土</th><th class=\"column-8\">日</th>\n</tr>\n</thead>\n<tbody class=\"row-hover\">\n<tr class=\"row-2 even\">\n\t<td class=\"column-1\">対面診療：午前<br />\n（9:00～12:00）</td><td class=\"column-2\">／</td><td class=\"column-3\">○</td><td class=\"column-4\">○</td><td class=\"column-5\">○</td><td class=\"column-6\">○</td><td class=\"column-7\">／</td><td class=\"column-8\">／</td>\n</tr>\n<tr class=\"row-3 odd\">\n\t<td class=\"column-1\">対面診療：午後<br />\n（14:00～17:00）</td><td class=\"column-2\">○</td><td class=\"column-3\">○</td><td class=\"column-4\">○</td><td class=\"column-5\">○</td><td class=\"column-6\">島根大学</td><td class=\"column-7\">／</td><td class=\"column-8\">／</td>\n</tr>\n<tr class=\"row-4 even\">\n\t<td class=\"column-1\">オンライン診療<br />\n（8:30〜18:00）</td><td class=\"column-2\">△</td><td class=\"column-3\">△</td><td class=\"column-4\">△</td><td class=\"column-5\">△</td><td class=\"column-6\">△</td><td class=\"column-7\">△</td><td class=\"column-8\">△</td>\n</tr>\n</tbody>\n</table>\n\n<span class=\"meditimenote\">※ melmoの予約システムで予約できる時間は予約可能になっています。上記の表にない時間でも安心してご予約ください。（上記の時間以外は、時間外診療となります）\n<br>※ 休診となっている時間でも受診いただける場合があります。受診されたい方は、出雲漢方クリニックのLINE公式アカウントまでご相談ください。</span>\n<p>休診日　<span class=\"clinicholiday\">土・日</span></p>\n<p><a onclick=\"javascript:pageTracker._trackPageview('/outgoing/clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online');\" class=\"big-button\"  href=\"https://clinics-app.com/clinic/6200901c030daf257f78c01f/exclusive_reservation?method=online\" target=\"_blank\" rel=\"noopener noreferrer\">診療の予約をする</a></p>\n<h3>アクセス</h3>\n<p>住所：島根県出雲市今市町736-11</p>\n<p><iframe style=\"border: 0;\" src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d26029.15686636629!2d132.71986467910156!3d35.364465200000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3557433411ef6fad%3A0xd3eaedb2e6c3a4cc!2z5Ye66Zuy5ryi5pa544Kv44Oq44OL44OD44Kv!5e0!3m2!1sja!2sjp!4v1660632018988!5m2!1sja!2sjp\" width=\"700\" height=\"450\" allowfullscreen=\"allowfullscreen\"></iframe></p>\n<h4 id=\"anchor-parking\">車でお越しの方へ</h4>\n<p><img fetchpriority=\"high\" decoding=\"async\" src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1.jpg\" alt=\"\" width=\"960\" height=\"720\" class=\"size-full wp-image-1815 alignnone\" srcset=\"https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1.jpg 960w, https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1-300x225.jpg 300w, https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1-240x180.jpg 240w, https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1-768x576.jpg 768w, https://izumo-kampo.clinic/wp-content/uploads/2023/01/B5CFFA6A-49D2-4F9C-B604-B7C2D6F3463F-1-480x360.jpg 480w\" sizes=\"(max-width: 960px) 100vw, 960px\" data-eio=\"j\" /></p>\n<p>患者さん用の駐車場はこの写真の軽自動車の隣（駐車場で言うと真ん中の位置）になります。</p>\n<p>駐車場には１台しか停められないため、予約時間以降にお越しください。予約時間前にいらっしゃると満車で停められない場合があります。</p>\n<p>また、同じ時間に診療が入っている患者さんがいる時は満車になってることがあります。その場合はお手数ですが、院内のスタッフにお声がけください（コロナの方は<a onclick=\"javascript:pageTracker._trackPageview('/outgoing/lin.ee/J5alWzJ');\"  href=\"https://lin.ee/J5alWzJ\" target=\"_blank\" rel=\"noopener noreferrer\">LINE公式アカウント</a>までご連絡ください）。</p></div>\n\n</section>\n