>]<br /></span>\n          <span class=\"footer_clinicholiday\">休診日：　土・日</span>\n        </p>\n        <div id=\"footer_add\">\n          <!-- フッターに記載する内容（#bottom_contents） -->\n        </div>\n        <div id=\"add_footer_data\"></div>\n        <address class=\"address\">\n          Copyright &copy; 出雲漢方クリニック All Rights Reserved.\n        </address>\n      </div>\n    </footer>\n    <div id=\"sidr\" class=\"sidr right\">\n      <p class=\"close\">\n        <a href=\"javascript:void(0)\" class=\"mobile_menu\">Close</a>\n      </p>\n      <p class=\"backhome\"><a href=\"/top.html\">HOME</a></p>\n      <div class=\"banner smart_phonetop\">\n        <ul>\n          <li>\n            <a href=\"https://lin.ee/J5alWzJ\" target=\"_blank\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_line.png\" alt=\"LINE公式アカウント問い合わせ\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/reserve.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/09/banner_reserve.png\" alt=\"診療予約について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/q_and_a.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2022/10/4d767dee6af9188b3d6c0424c1a66b01.png\"\n                alt=\"よくある質問\" data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/partnership-shinkyu.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/05/Twitter.png\" alt=\"提携鍼灸院について\"\n                data-eio=\"j\" />\n            </a>\n          </li>\n          <li>\n            <a href=\"/blog.html\">\n              <img src=\"https://izumo-kampo.clinic/wp-content/uploads/2023/03/53dca034c608bbba0219914e69b10442-1.png\"\n                alt=\"院長ブログ\" data-eio=\"j\" />\n            </a>\n          </li>\n        </ul>\n      </div>\n      <ul id=\"menu-ma